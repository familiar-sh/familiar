{
  "name": "kanban-agent",
  "version": "0.4.0",
  "description": "A macOS Electron desktop app with kanban board, terminals, and block editor for agentic AI coding workflows",
  "main": "./out/main/index.js",
  "bin": {
    "kanban-agent": "./dist/cli/index.mjs"
  },
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "build:cli": "tsup",
    "build:app": "npm run build && npm run build:cli && electron-builder --config electron-builder.config.js",
    "build:app:arm64": "npm run build && npm run build:cli && electron-builder --config electron-builder.config.js --mac --arm64",
    "build:app:x64": "npm run build && npm run build:cli && electron-builder --config electron-builder.config.js --mac --x64",
    "postinstall": "electron-rebuild -f -w node-pty || true",
    "rebuild": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@blocknote/core": "^0.47.1",
    "@blocknote/mantine": "^0.47.1",
    "@blocknote/react": "^0.47.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "^8.3.16",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cmdk": "^1.1.1",
    "commander": "^14.0.3",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.465.0",
    "nanoid": "^5.1.6",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^3.7.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
